{
  "name": "sigil-vscode",
  "displayName": "Sigil",
  "description": "Sigil daemon panel — suggestions, status, and event viewer",
  "version": "0.2.0",
  "publisher": "wambozi",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/wambozi/sigil"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sigil-sidebar",
          "title": "Sigil",
          "icon": "media/sigil-icon.svg"
        }
      ]
    },
    "views": {
      "sigil-sidebar": [
        {
          "type": "webview",
          "id": "sigil.panel",
          "name": "Sigil"
        }
      ]
    },
    "configuration": {
      "title": "Sigil",
      "properties": {
        "sigil.socketPath": {
          "type": "string",
          "default": "",
          "description": "Path to sigild Unix socket. Auto-detected from $XDG_RUNTIME_DIR if empty."
        },
        "sigil.metricsRefreshInterval": {
          "type": "number",
          "default": 10000,
          "minimum": 2000,
          "description": "How often to poll daemon status and metrics (milliseconds)."
        },
        "sigil.suggestionDisplayMode": {
          "type": "string",
          "default": "timeline",
          "enum": ["timeline", "active-list"],
          "enumDescriptions": [
            "Show all suggestions chronologically",
            "Show only pending suggestions, sorted by confidence"
          ],
          "description": "How to display suggestions in the panel."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^3.0.0"
  }
}
